# ---------- MongoDB Atlas (source) ----------
# From Atlas > Connect > Drivers. Keep the password URL-encoded.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGO_DB="retail"

# ---------- Azure Data Lake Storage Gen2 (bronze) ----------
ADLS_ACCOUNT_NAME="myadlsaccount"
ADLS_FILESYSTEM="bronze"
# Use either a connection string OR DefaultAzureCredential (az login). Connection string is simplest for a learning project.
ADLS_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"

# ---------- Postgres (silver/gold warehouse) ----------
PGHOST="localhost"
PGPORT="5432"
PGDATABASE="warehouse"
PGUSER="bi"
PGPASSWORD="change-me"

# ---------- Azure OpenAI (the agent's brain) ----------
AZURE_OPENAI_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com/"
AZURE_OPENAI_API_KEY="..."
AZURE_OPENAI_API_VERSION="2024-10-21"
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"
